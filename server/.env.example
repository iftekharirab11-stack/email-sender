# MailMind Server Environment Variables

# Server Port (default: 3001)
PORT=3001

# AI Provider API Keys (fill in ONE or more)
# Mistral AI (FREE tier available) - get key at https://console.mistral.ai
MISTRAL_API_KEY=your-mistral-key-here

# Groq (FREE, very fast) - get key at https://console.groq.com/keys
GROQ_API_KEY=your-groq-key-here

# OpenAI (paid)
OPENAI_API_KEY=your-openai-key-here

# Google Gemini
GEMINI_API_KEY=your-gemini-key-here

# Together AI
TOGETHER_API_KEY=your-together-key-here